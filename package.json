{
  "name": "open-fusion",
  "version": "0.1.0",
  "private": true,
  "description": "OpenAI-compatible LLM gateway built with NestJS.",
  "license": "UNLICENSED",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "format": "prettier --check \"{src,test}/**/*.ts\" \"*.json\"",
    "format:write": "prettier --write \"{src,test}/**/*.ts\" \"*.json\"",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "start": "node dist/main.js",
    "start:dev": "ts-node src/main.ts",
    "test": "jest --runInBand",
    "test:e2e": "jest --config jest-e2e.config.js --runInBand",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0"
  },
  "overrides": {
    "multer": "2.2.0"
  }
}
